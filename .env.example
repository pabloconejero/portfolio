# ── App ───────────────────────────────────────────────────────────────────────
# Local dev: file:./portfolio-v2.db  |  Docker: set via docker-compose.yml
DATABASE_URL=file:./portfolio-v2.db

# Generate a strong secret: openssl rand -base64 32
PAYLOAD_SECRET=

# ── Email ─────────────────────────────────────────────────────────────────────
# Domain Postfix is allowed to send from (must match your server's hostname)
SMTP_DOMAIN=yourdomain.com

# From address on notification emails
SMTP_FROM=noreply@yourdomain.com

# Inbox that receives contact form notifications
CONTACT_EMAIL=you@yourdomain.com

# ── Optional: relay through external SMTP (Gmail, Brevo, Sendgrid…) ──────────
# Uncomment RELAYHOST lines in docker-compose.yml and fill in credentials here
# SMTP_RELAY_USER=
# SMTP_RELAY_PASSWORD=
